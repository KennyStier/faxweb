# Copy to /etc/faxweb.env and edit. Keep it readable only by the service user:
#   sudo install -m 600 -o faxweb -g faxweb faxweb.env.example /etc/faxweb.env

# REQUIRED — shared password for the login gate.
FAX_PASSWORD=change-me-to-something-strong

# CUPS fax queue name and the epfax2 binary (defaults shown).
FAX_QUEUE=EPSON_FAX2
FAX_EPFAX2_BIN=epfax2

# Where to bind. 0.0.0.0 = reachable from the LAN. Use 127.0.0.1 if fronting
# it with a reverse proxy on the same host.
FAX_BIND=0.0.0.0
FAX_PORT=8080

# Data dir (uploads, job log, session key). Must be writable by the service user.
FAX_DATA_DIR=/opt/faxweb/data

# Upload limit (MB) and fax-number sanity bounds.
FAX_MAX_MB=20
FAX_PHONE_MIN_DIGITS=7
FAX_PHONE_MAX_DIGITS=20

# Set to 1 to test the UI without actually sending faxes.
FAX_DRY_RUN=0

# Optional: pin the session-signing key (else one is generated in FAX_DATA_DIR).
# FAX_SECRET_KEY=paste-a-long-random-string
